#!/bin/bash
##SBATCH --partition=long
#SBATCH --cpus-per-task=16
#SBATCH --gres=gpu:l40s:1
#SBATCH --mem=64G
#SBATCH --time=23:59:00
set -e

date
hostname

cd $SLURM_SUBMIT_DIR
pwd

module load python/3.11 cuda/12.6

cp -r /home/semiki/projects/aip-wolfg/semiki/COPT-MT $SLURM_TMPDIR
cd $SLURM_TMPDIR/COPT-MT

source .venv/bin/activate

echo $@
eval $@


echo "All done in sbatch."
date
